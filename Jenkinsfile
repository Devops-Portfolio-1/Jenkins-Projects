//Base Pipeline Script 

pipeline {
    agent any
    stages {
        
        stage("build jar") {
            steps {
                script {
                    echo "building jar file"
                    
                }
            }
        }
        stage("build image") {
            steps {
                script {
                    echo "building image"
                   
                }
            }
        }
        stage("deploy") {
            steps {
                script {
                    echo "deploying"
                    
                }
            }
        }
    }   
}